{
  "expo": {
    "name": "EyeGo Driver",
    "slug": "eyego-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eyego-driver",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e151a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eyego.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EyeGo Driver needs your location to go online and track trips.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "EyeGo Driver uses your location to broadcast your position to passengers.",
        "NSCameraUsageDescription": "EyeGo Driver needs camera access to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "EyeGo Driver needs photo library access to update your profile photo.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e151a"
      },
      "package": "com.eyego.driver",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow EyeGo Driver to use your location to broadcast your position to passengers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EyeGo Driver to access your photos to update your profile picture."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1b1842be-f2bb-43b2-8b56-37693a7e85cd"
      }
    },
    "owner": "spencergeee"
  }
}
