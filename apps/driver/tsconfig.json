{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@eyego/config": ["../../packages/config/src/index.ts"],
      "@eyego/ui": ["../../packages/ui/src/index.ts"],
      "@eyego/api": ["../../packages/api/src/index.ts"],
      "@eyego/types": ["../../packages/types/src/index.ts"],
      "@eyego/utils": ["../../packages/utils/src/index.ts"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
