# Copy this file to .env and fill in your values.
# Never commit .env with real keys to source control.
# For production/CI, set secrets via EAS secrets (eas secret:create).

# API server port (auto-detected in Expo Go; change if your backend runs on a different port)
EXPO_PUBLIC_API_PORT=5020

# Fallback API URL used when auto-detection fails (e.g. production builds)
EXPO_PUBLIC_API_URL=http://localhost:5020/v1

# ╔═══════════════════════════════════════════════════════════════╗
# ║ NOTE: EyeGo no longer uses Mapbox. Maps use MapLibre GL     ║
# ║ Native + OpenFreeMap tiles (free, no key needed).            ║
# ║ The old EXPO_PUBLIC_MAPBOX_TOKEN is no longer referenced     ║
# ║ by any code and can be removed from your .env.              ║
# ╚═══════════════════════════════════════════════════════════════╝

# Paystack public key — get yours at https://dashboard.paystack.com/#/settings/developer
# Use pk_test_... for development and pk_live_... for production (set via EAS secrets)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_KEY

# Expo EAS project ID (used for push notifications)
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here
