{
  "version": 8,
  "name": "EyeGo Dark",
  "metadata": {
    "description": "Premium dark map theme for EyeGo — green-accented, no API key required, works with OpenFreeMap free tiles.",
    "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a> · <a href=\"https://openmaptiles.org\" target=\"_blank\">OpenMapTiles</a> · <a href=\"https://openstreetmap.org\" target=\"_blank\">OpenStreetMap</a>"
  },
  "sources": {
    "openfreemap": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a>"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#0B0E14" }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "park", "#132A1D",
          "forest", "#102619",
          "cemetery", "#1D212B",
          "hospital", "#2B1720",
          "school", "#1A2038",
          "industrial", "#1B1E28",
          "commercial", "#181B24",
          "#171A22"
        ],
        "fill-opacity": 0.85
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#123449"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#1B4B63",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "building",
      "paint": {
        "fill-color": "#242938",
        "fill-opacity": 0.8,
        "fill-outline-color": "#3A415A"
      }
    },
    {
      "id": "aeroway-polygon",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "aeroway",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#1C2030",
        "fill-opacity": 0.65
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#262C3D",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 2]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service"],
      "paint": {
        "line-color": "#333A4F",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2],
        "line-opacity": 0.85
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "paint": {
        "line-color": "#4A5470",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 4],
        "line-opacity": 0.95
      }
    },
    {
      "id": "road-highway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "paint": {
        "line-color": ["interpolate", ["linear"], ["zoom"], 8, "#3E4964", 12, "#3F6E4E"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 16, 6],
        "line-opacity": 1
      }
    },
    {
      "id": "road-major-bright",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "paint": {
        "line-color": "#6B7590",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.5, 16, 2],
        "line-opacity": 0.4
      }
    },
    {
      "id": "road-highway-bright",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "paint": {
        "line-color": "#4BE277",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 16, 3],
        "line-opacity": 0.4
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "boundary",
      "filter": ["in", "admin_level", 2, 4],
      "paint": {
        "line-color": "rgba(75, 226, 119, 0.28)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 12, 1.5],
        "line-dasharray": [3, 3]
      }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.08,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(240, 240, 245, 0.9)",
        "text-halo-color": "#0B0E14",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 8, 0, 10, 1]
      }
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(240, 240, 245, 0.65)",
        "text-halo-color": "#0B0E14",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-label-country",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 10, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(240, 240, 245, 0.55)",
        "text-halo-color": "#0B0E14",
        "text-halo-width": 2
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "motorway", "trunk", "primary"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "symbol-placement": "line",
        "symbol-spacing": 400,
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "rgba(240, 240, 245, 0.5)",
        "text-halo-color": "#0B0E14",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 16, 18],
        "symbol-placement": "line",
        "symbol-spacing": 500
      },
      "paint": {
        "text-color": "rgba(120, 200, 230, 0.5)",
        "text-halo-color": "#0B0E14",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "poi",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-max-width": 8,
        "icon-allow-overlap": false
      },
      "paint": {
        "text-color": "rgba(240, 240, 245, 0.55)",
        "text-halo-color": "#0B0E14",
        "text-halo-width": 1
      }
    }
  ],
  "id": "eyego-dark"
}
