{
  "version": 8,
  "name": "EyeGo Dark",
  "metadata": {
    "description": "Premium dark map theme for EyeGo — desaturated ink base so roads/route/pins own the hierarchy, muted brand-green reserved for highways and boundaries. No API key required, works with OpenFreeMap free tiles.",
    "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a> · <a href=\"https://openmaptiles.org\" target=\"_blank\">OpenMapTiles</a> · <a href=\"https://openstreetmap.org\" target=\"_blank\">OpenStreetMap</a>"
  },
  "sources": {
    "openfreemap": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a>"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#0A0C10" }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "park", "#101C16",
          "forest", "#0D1912",
          "cemetery", "#171A20",
          "hospital", "#231519",
          "school", "#161A26",
          "industrial", "#15171E",
          "commercial", "#13151B",
          "#121319"
        ],
        "fill-opacity": 0.8
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#0E2C3A"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#1C5770",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#1B1F29",
        "fill-opacity": 0.82,
        "fill-outline-color": "#2C3340"
      }
    },
    {
      "id": "aeroway-polygon",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "aeroway",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#171A22",
        "fill-opacity": 0.65
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#1E222C",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 2],
        "line-dasharray": [2, 1.6]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service"],
      "minzoom": 12,
      "paint": {
        "line-color": "#282E3B",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2],
        "line-opacity": 0.85
      }
    },
    {
      "id": "road-major-case",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#171A22",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2.4, 16, 7],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#525C72",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 4],
        "line-opacity": 1
      }
    },
    {
      "id": "road-highway-case",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "minzoom": 6,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#12151B",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 2.5, 16, 8.5],
        "line-opacity": 1
      }
    },
    {
      "id": "road-highway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "minzoom": 6,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": ["interpolate", ["linear"], ["zoom"], 6, "#4C5872", 11, "#3E9E68", 15, "#4BE277"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 16, 6],
        "line-opacity": 1
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "boundary",
      "filter": ["in", "admin_level", 2, 4],
      "paint": {
        "line-color": "rgba(75, 226, 119, 0.22)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 12, 1.5],
        "line-dasharray": [3, 3]
      }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(232, 236, 240, 0.92)",
        "text-halo-color": "#0A0C10",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 8, 0, 10, 1]
      }
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "text-letter-spacing": 0.02,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(232, 236, 240, 0.6)",
        "text-halo-color": "#0A0C10",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-label-country",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 10, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.14,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(232, 236, 240, 0.5)",
        "text-halo-color": "#0A0C10",
        "text-halo-width": 2
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "motorway", "trunk", "primary"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "text-letter-spacing": 0.02,
        "symbol-placement": "line",
        "symbol-spacing": 400,
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "rgba(232, 236, 240, 0.5)",
        "text-halo-color": "#0A0C10",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 16, 18],
        "symbol-placement": "line",
        "symbol-spacing": 500
      },
      "paint": {
        "text-color": "rgba(94, 189, 219, 0.55)",
        "text-halo-color": "#0A0C10",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": ["<=", ["get", "rank"], 15],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 9, 18, 13],
        "text-max-width": 8,
        "icon-allow-overlap": false,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(232, 236, 240, 0.55)",
        "text-halo-color": "#0A0C10",
        "text-halo-width": 1
      }
    }
  ],
  "id": "eyego-dark"
}
