{
  "version": 8,
  "name": "EyeGo Light",
  "metadata": {
    "description": "Premium light map theme for EyeGo — warm paper base (not default Tailwind slate) with near-white roads cut by warm-taupe casings, brand blue reserved for highways at close zoom. No API key required, works with OpenFreeMap free tiles.",
    "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a> · <a href=\"https://openmaptiles.org\" target=\"_blank\">OpenMapTiles</a> · <a href=\"https://openstreetmap.org\" target=\"_blank\">OpenStreetMap</a>"
  },
  "sources": {
    "openfreemap": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a>"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#EFEBE2" }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "park", "#DBE3D0",
          "forest", "#D2DEC8",
          "cemetery", "#E5E0D6",
          "hospital", "#F1DEDB",
          "school", "#E1DFEC",
          "industrial", "#E7E2D7",
          "commercial", "#EBE6DB",
          "#EAE5DA"
        ],
        "fill-opacity": 0.9
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#BAD3E0"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#BAD3E0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#E6E1D5",
        "fill-opacity": 0.85,
        "fill-outline-color": "#D3CBB9"
      }
    },
    {
      "id": "aeroway-polygon",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "aeroway",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#E2DCCE",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#DDD6C7",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 2],
        "line-dasharray": [2, 1.6]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service"],
      "minzoom": 12,
      "paint": {
        "line-color": "#FBFAF6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2],
        "line-opacity": 0.95
      }
    },
    {
      "id": "road-major-case",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#CFC5AE",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 2.4, 16, 7],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#FDFCFA",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 4],
        "line-opacity": 1
      }
    },
    {
      "id": "road-highway-case",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "minzoom": 6,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#B7ACC1",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 2.5, 16, 8.5],
        "line-opacity": 1
      }
    },
    {
      "id": "road-highway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "minzoom": 6,
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": ["interpolate", ["linear"], ["zoom"], 6, "#8E8875", 11, "#3D6FE0", 15, "#2F6FED"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 16, 6],
        "line-opacity": 1
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "boundary",
      "filter": ["in", "admin_level", 2, 4],
      "paint": {
        "line-color": "rgba(47, 111, 237, 0.25)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 12, 1.5],
        "line-dasharray": [3, 3]
      }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(38, 32, 24, 0.82)",
        "text-halo-color": "#EFEBE2",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 8, 0, 10, 1]
      }
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet"],
      "minzoom": 14,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "text-letter-spacing": 0.02,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(38, 32, 24, 0.6)",
        "text-halo-color": "#EFEBE2",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-label-country",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 10, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.14,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(38, 32, 24, 0.55)",
        "text-halo-color": "#EFEBE2",
        "text-halo-width": 2
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "motorway", "trunk", "primary"],
      "minzoom": 10,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "text-letter-spacing": 0.02,
        "symbol-placement": "line",
        "symbol-spacing": 400,
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "rgba(38, 32, 24, 0.5)",
        "text-halo-color": "#EFEBE2",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 16, 18],
        "symbol-placement": "line",
        "symbol-spacing": 500
      },
      "paint": {
        "text-color": "rgba(47, 111, 237, 0.55)",
        "text-halo-color": "#EFEBE2",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "poi",
      "minzoom": 16,
      "filter": ["<=", ["get", "rank"], 15],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 9, 18, 13],
        "text-max-width": 8,
        "icon-allow-overlap": false,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(38, 32, 24, 0.5)",
        "text-halo-color": "#EFEBE2",
        "text-halo-width": 1
      }
    }
  ],
  "id": "eyego-light"
}
