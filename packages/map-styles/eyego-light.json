{
  "version": 8,
  "name": "EyeGo Light",
  "metadata": {
    "description": "Premium light map theme for EyeGo — clean white/gray, no API key required, works with OpenFreeMap free tiles.",
    "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a> · <a href=\"https://openmaptiles.org\" target=\"_blank\">OpenMapTiles</a> · <a href=\"https://openstreetmap.org\" target=\"_blank\">OpenStreetMap</a>"
  },
  "sources": {
    "openfreemap": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "attribution": "<a href=\"https://openfreemap.org\" target=\"_blank\">OpenFreeMap</a>"
    }
  },
  "glyphs": "https://fonts.openmaptiles.org/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#F1F5F9" }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "park", "#DCFCE7",
          "forest", "#D1FAE5",
          "cemetery", "#E2E8F0",
          "hospital", "#FEE2E2",
          "school", "#E0E7FF",
          "industrial", "#E2E8F0",
          "commercial", "#F1F5F9",
          "#EDF2F7"
        ],
        "fill-opacity": 0.9
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#BFDBFE"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#BFDBFE",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "building",
      "paint": {
        "fill-color": "#E2E8F0",
        "fill-opacity": 0.8,
        "fill-outline-color": "#CBD5E1"
      }
    },
    {
      "id": "aeroway-polygon",
      "type": "fill",
      "source": "openfreemap",
      "source-layer": "aeroway",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#E2E8F0",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#E2E8F0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 2]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service"],
      "paint": {
        "line-color": "#E2E8F0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 16, 2],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "secondary", "tertiary"],
      "paint": {
        "line-color": "#CBD5E1",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 16, 4],
        "line-opacity": 1
      }
    },
    {
      "id": "road-highway",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "paint": {
        "line-color": ["interpolate", ["linear"], ["zoom"], 8, "#94A3B8", 12, "#3B82F6"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 16, 6],
        "line-opacity": 1
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openfreemap",
      "source-layer": "boundary",
      "filter": ["in", "admin_level", 2, 4],
      "paint": {
        "line-color": "rgba(59, 130, 246, 0.25)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 12, 1.5],
        "line-dasharray": [3, 3]
      }
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.08,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(15, 23, 42, 0.75)",
        "text-halo-color": "#F1F5F9",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 8, 0, 10, 1]
      }
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["in", "class", "village", "hamlet"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(15, 23, 42, 0.55)",
        "text-halo-color": "#F1F5F9",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-label-country",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 10, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "symbol-sort-key": ["get", "rank"]
      },
      "paint": {
        "text-color": "rgba(15, 23, 42, 0.5)",
        "text-halo-color": "#F1F5F9",
        "text-halo-width": 2
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "transportation_name",
      "filter": ["in", "class", "motorway", "trunk", "primary"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "symbol-placement": "line",
        "symbol-spacing": 400,
        "text-rotation-alignment": "map"
      },
      "paint": {
        "text-color": "rgba(15, 23, 42, 0.45)",
        "text-halo-color": "#F1F5F9",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 10, 16, 18],
        "symbol-placement": "line",
        "symbol-spacing": 500
      },
      "paint": {
        "text-color": "rgba(37, 99, 235, 0.5)",
        "text-halo-color": "#F1F5F9",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "openfreemap",
      "source-layer": "poi",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-max-width": 8,
        "icon-allow-overlap": false
      },
      "paint": {
        "text-color": "rgba(15, 23, 42, 0.5)",
        "text-halo-color": "#F1F5F9",
        "text-halo-width": 1
      }
    }
  ],
  "id": "eyego-light"
}
