# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=https://api.eyego.app

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/eyego_db

# ─────────────────────────────────────────
# Redis (Upstash)
# ─────────────────────────────────────────
REDIS_URL=redis://default:password@endpoint.upstash.io:6379

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_min_64_chars_access_secret_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_min_64_chars_refresh_secret_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─────────────────────────────────────────
# Paystack
# ─────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# Africa's Talking (SMS / OTP)
# ─────────────────────────────────────────
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=EyeGo

# ─────────────────────────────────────────
# Firebase Admin SDK
# ─────────────────────────────────────────
FIREBASE_PROJECT_ID=eyego-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@eyego-app.iam.gserviceaccount.com

# ─────────────────────────────────────────
# APNs / iOS Live Activities (ActivityKit) — optional
# Separate from Firebase above: Live Activity lock-screen updates go direct
# to Apple's push gateway, not through FCM. See eyego-api/src/config/env.js
# for the full "how to obtain these" checklist.
# ─────────────────────────────────────────
APNS_AUTH_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_P8_KEY_HERE\n-----END PRIVATE KEY-----\n"
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_LIVE_ACTIVITY_TOPIC=com.eyego.rider.EyeGoLiveActivity
APNS_ENVIRONMENT=sandbox

# ─────────────────────────────────────────
# Mapbox
# ─────────────────────────────────────────
MAPBOX_SECRET_TOKEN=sk.eyJ1IjoieW91cl91c2VybmFtZSJ9.your_token_here
MAPBOX_PUBLIC_TOKEN=pk.eyJ1IjoieW91cl91c2VybmFtZSJ9.your_public_token_here
ETA_FALLBACK_SPEED_KPH=30

# ─────────────────────────────────────────
# Cloudinary
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────
# Admin (Phase 1 — simple secret key)
# ─────────────────────────────────────────
ADMIN_SECRET_KEY=change_me_strong_admin_secret_key

# ─────────────────────────────────────────
# OTA deploy console (optional — admin "OTA Deploy" page)
# EXPO_TOKEN: expo.dev → Account settings → Access tokens (read-only use here:
#   lists published updates/channels for both apps on the admin page).
# GITHUB_TOKEN: fine-grained PAT with Actions read+write on the repo (or a
#   classic token with `repo` scope). Triggers .github/workflows/ota-update.yml
#   and reads run status.
# GITHUB_REPO: owner/repo of this monorepo.
# ─────────────────────────────────────────
EXPO_TOKEN=
GITHUB_TOKEN=
GITHUB_REPO=SpencerGeee/EyeGo-V2
GITHUB_REF=main
OTA_WORKFLOW_FILE=ota-update.yml

# ─────────────────────────────────────────
# Fare Configuration (can migrate to DB later)
# ─────────────────────────────────────────
ECO_BASE_FARE=20.00
ECO_PER_KM_RATE=5.00
COMFORT_BASE_FARE=30.00
COMFORT_PER_KM_RATE=7.00
PREMIUM_BASE_FARE=50.00
PREMIUM_PER_KM_RATE=16.00
DOORSTEP_SURCHARGE=5.00
HEAVY_LOAD_SURCHARGE=8.00
FREE_DEVIATION_KM=1.5
PLATFORM_COMMISSION=0.15
MIN_OCCUPANCY_TO_DEPART=5
SEAT_HOLD_DURATION_MINUTES=10
DRIVER_MIN_WALLET_BALANCE=5.00
DRIVER_REQUIRED_WALLET_TO_GO_ONLINE=20.00
DRIVER_MIN_WITHDRAWAL=20.00

# ─────────────────────────────────────────
# Safety / RideCheck (all optional — sensible code defaults)
# ─────────────────────────────────────────
# Meters off the expected route before a deviation safety-check fires (default 350)
DEVIATION_THRESHOLD_M=350
# Seconds stopped before a stopped-too-long safety-check fires (default 180)
STOPPED_THRESHOLD_SEC=180
# Cooldown between safety-checks for the same trip, seconds (default 300)
SAFETY_CHECK_COOLDOWN_SEC=300
# Set to false to skip Ghana-bounds validation of driver GPS (default enabled)
GEO_VALIDATION_ENABLED=true
# Anonymized contact relay number (Phase 3A sandbox placeholder)
CONTACT_RELAY_NUMBER=

# ─────────────────────────────────────────
# Sentry (optional — error tracking off when unset)
# ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─────────────────────────────────────────
# Server
# ─────────────────────────────────────────
# Comma-separated allowed CORS origins in production (falls back to hardcoded defaults)
CORS_ALLOWED_ORIGINS=https://eyego.app,https://driver.eyego.app
# Graceful shutdown timeout in ms before forcing exit
SHUTDOWN_TIMEOUT_MS=30000
# Optional override for the seat-hold sweep cutoff, minutes.
# Unset = SEAT_HOLD_DURATION_MINUTES + 5 grace (keeps both knobs in sync).
# SEAT_HOLD_MINUTES=15
