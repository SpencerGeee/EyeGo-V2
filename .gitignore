# Dependencies
**/node_modules/

# Expo / React Native build artifacts
.expo/
dist/
**/*/build/
**/*/dist/

# Generated native projects (expo prebuild) — scoped to each app's own
# top-level ios/android folder only, NOT **/ios/, which also matched (and
# silently dropped) hand-written native source under apps/*/modules/*/ios/
# and similar custom Expo module/target folders.
apps/*/ios/
apps/*/android/

# Env files (contain secrets)
.env
.env.local
.env*.local
apps/*/.env
apps/*/.env.local
apps/*/.env*.local

# Logs
*.log

# TypeScript
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# Prisma
**/prisma/dev.db
**/prisma/dev.db-journal

# EAS / Firebase / signing
google-service-account.json
GoogleService-Info.plist
google-services.json
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Sentry
sentry.properties

# IDE
.idea/
*.swp
*.swo
*~
